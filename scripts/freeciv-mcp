#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
cd "${REPO_ROOT}"

mkdir -p runtime/logs
{
  printf '[%s] start cwd=%s args=' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$(pwd)"
  printf '%q ' "$@"
  printf '\n'
} >> runtime/logs/freeciv-mcp-wrapper.log

exec python3 -m freeciv_agent.mcp_server "$@" 2>> runtime/logs/freeciv-mcp-wrapper.log
