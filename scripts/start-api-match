#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

MODEL="${MODEL:-gpt-5.4-nano}"
REASONING_EFFORT="${REASONING_EFFORT:-low}"
CONTROL_URL="${CONTROL_URL:-http://127.0.0.1:8787}"
TURN_TIMEOUT="${TURN_TIMEOUT:-180}"
TURN_RETRIES="${TURN_RETRIES:-1}"
PLAYERS="${PLAYERS:-AgentA AgentB}"
if [[ -z "${PLAYERS//[[:space:]]/}" ]]; then
  PLAYERS="AgentA AgentB"
fi
MCP_VERSIONS="${MCP_VERSIONS:-}"
MCP_ARTIFACT_MODE="${MCP_ARTIFACT_MODE:-off}"
MCP_ARTIFACT_MODES="${MCP_ARTIFACT_MODES:-}"
MCP_ARTIFACT_PREVIEW_CHARS="${MCP_ARTIFACT_PREVIEW_CHARS:-800}"
NARRATIVE_LOG="${NARRATIVE_LOG:-0}"
NARRATIVE_PLAYERS="${NARRATIVE_PLAYERS:-}"
PUBLIC_TURN_MESSAGE="${PUBLIC_TURN_MESSAGE:-0}"
VICTORY_MODES="${VICTORY_MODES:-}"
MAX_TOOL_ITERATIONS="${MAX_TOOL_ITERATIONS:-24}"
MAX_OUTPUT_TOKENS="${MAX_OUTPUT_TOKENS:-4096}"
SCREEN_NAME="${SCREEN_NAME:-freeciv-api-match}"
LOG_FILE="${LOG_FILE:-${REPO_ROOT}/runtime/logs/api-match-runner.log}"
PID_FILE="${PID_FILE:-${REPO_ROOT}/runtime/run/api-match-runner.pid}"
STOP_FILE="${STOP_FILE:-${REPO_ROOT}/runtime/run/stop-api-match}"
RESET_SESSIONS="${RESET_SESSIONS:-1}"
RESET_NARRATIVE="${RESET_NARRATIVE:-${RESET_SESSIONS}}"
RESET_MCP_ARTIFACTS="${RESET_MCP_ARTIFACTS:-${RESET_SESSIONS}}"
START_VIEWERS="${START_VIEWERS:-1}"

usage() {
  cat <<EOF
Usage: $0

Starts or restarts only the detached API/MCP match loop against an already-running
Freeciv server/control API.

Environment overrides:
  MODEL=${MODEL}
  REASONING_EFFORT=${REASONING_EFFORT}
  TURN_TIMEOUT=${TURN_TIMEOUT}
  TURN_RETRIES=${TURN_RETRIES}
  PLAYERS=${PLAYERS}
  MCP_VERSIONS=${MCP_VERSIONS}
  MCP_ARTIFACT_MODE=${MCP_ARTIFACT_MODE}
  MCP_ARTIFACT_MODES=${MCP_ARTIFACT_MODES}
  MCP_ARTIFACT_PREVIEW_CHARS=${MCP_ARTIFACT_PREVIEW_CHARS}
  MAX_TOOL_ITERATIONS=${MAX_TOOL_ITERATIONS}
  MAX_OUTPUT_TOKENS=${MAX_OUTPUT_TOKENS}
  NARRATIVE_LOG=${NARRATIVE_LOG}
  NARRATIVE_PLAYERS=${NARRATIVE_PLAYERS}
  PUBLIC_TURN_MESSAGE=${PUBLIC_TURN_MESSAGE}
  VICTORY_MODES=${VICTORY_MODES}
  RESET_SESSIONS=${RESET_SESSIONS}
  RESET_NARRATIVE=${RESET_NARRATIVE}
  RESET_MCP_ARTIFACTS=${RESET_MCP_ARTIFACTS}
  START_VIEWERS=${START_VIEWERS}
  CONTROL_URL=${CONTROL_URL}
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" || "${1:-}" == "help" ]]; then
  usage
  exit 0
fi

mkdir -p "${REPO_ROOT}/runtime/logs" "${REPO_ROOT}/runtime/run"

if [[ -f "${REPO_ROOT}/.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  source "${REPO_ROOT}/.env"
  set +a
fi

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "OPENAI_API_KEY is not set; cannot start API players." >&2
  exit 2
fi

screen -S "${SCREEN_NAME}" -X quit >/dev/null 2>&1 || true
for pattern in \
  "freeciv_agent.api_match_runner" \
  "freeciv_agent.api_turn_runner"
do
  for pid in $(pgrep -f "${pattern}" 2>/dev/null || true); do
    [[ "${pid}" != "$$" && "${pid}" != "${BASHPID:-$$}" && "${pid}" != "${PPID}" ]] || continue
    kill "${pid}" >/dev/null 2>&1 || true
  done
done
sleep 0.5
for pattern in \
  "freeciv_agent.api_match_runner" \
  "freeciv_agent.api_turn_runner"
do
  for pid in $(pgrep -f "${pattern}" 2>/dev/null || true); do
    [[ "${pid}" != "$$" && "${pid}" != "${BASHPID:-$$}" && "${pid}" != "${PPID}" ]] || continue
    kill -KILL "${pid}" >/dev/null 2>&1 || true
  done
done
rm -f "${STOP_FILE}"
: >"${LOG_FILE}"

args=(
  python3 -u -m freeciv_agent.api_match_runner
  --model "${MODEL}"
  --reasoning-effort "${REASONING_EFFORT}"
  --turn-timeout "${TURN_TIMEOUT}"
  --turn-retries "${TURN_RETRIES}"
  --control-url "${CONTROL_URL}"
  --mcp-artifact-mode "${MCP_ARTIFACT_MODE}"
  --mcp-artifact-preview-chars "${MCP_ARTIFACT_PREVIEW_CHARS}"
  --max-tool-iterations "${MAX_TOOL_ITERATIONS}"
  --max-output-tokens "${MAX_OUTPUT_TOKENS}"
  --clear-stop-file
  --players
)

for player in ${PLAYERS}; do
  args+=("${player}")
done

if [[ -n "${MCP_VERSIONS}" ]]; then
  args+=(--mcp-versions)
  for assignment in ${MCP_VERSIONS}; do
    args+=("${assignment}")
  done
fi

if [[ -n "${MCP_ARTIFACT_MODES}" ]]; then
  args+=(--mcp-artifact-modes)
  for assignment in ${MCP_ARTIFACT_MODES}; do
    args+=("${assignment}")
  done
fi

if [[ "${NARRATIVE_LOG}" != "0" ]]; then
  args+=(--narrative-log)
fi

if [[ -n "${NARRATIVE_PLAYERS}" ]]; then
  args+=(--narrative-players)
  for player in ${NARRATIVE_PLAYERS}; do
    args+=("${player}")
  done
fi

if [[ "${PUBLIC_TURN_MESSAGE}" != "0" ]]; then
  args+=(--public-turn-message)
fi

if [[ -n "${VICTORY_MODES}" ]]; then
  args+=(--victory-modes)
  for assignment in ${VICTORY_MODES}; do
    args+=("${assignment}")
  done
fi

if [[ "${RESET_SESSIONS}" != "0" ]]; then
  args+=(--reset-sessions)
fi

if [[ "${RESET_NARRATIVE}" != "0" ]]; then
  args+=(--reset-narrative)
fi

if [[ "${RESET_MCP_ARTIFACTS}" != "0" ]]; then
  args+=(--reset-mcp-artifacts)
fi

if [[ "${START_VIEWERS}" == "0" ]]; then
  args+=(--no-viewers)
fi

screen -dmS "${SCREEN_NAME}" bash -lc '
  set -euo pipefail
  cd "$1"
  log_file="$2"
  shift 2
  "$@" 2>&1 | tee -a "$log_file"
' _ "${REPO_ROOT}" "${LOG_FILE}" "${args[@]}"

for _ in {1..20}; do
  (screen -ls || true) | awk -v name="${SCREEN_NAME}" '$0 ~ name {split($1, a, "."); print a[1]; exit}' >"${PID_FILE}"
  if [[ -s "${PID_FILE}" ]]; then
    break
  fi
  sleep 0.25
done

if [[ ! -s "${PID_FILE}" ]]; then
  echo "API match loop failed to stay running. Recent log:" >&2
  tail -n 80 "${LOG_FILE}" >&2 || true
  exit 1
fi

echo "API match loop started screen=${SCREEN_NAME} pid=$(cat "${PID_FILE}") model=${MODEL} reasoning_effort=${REASONING_EFFORT} players=${PLAYERS} mcp_versions=${MCP_VERSIONS} mcp_artifact_mode=${MCP_ARTIFACT_MODE} mcp_artifact_modes=${MCP_ARTIFACT_MODES} narrative_log=${NARRATIVE_LOG} narrative_players=${NARRATIVE_PLAYERS} public_turn_message=${PUBLIC_TURN_MESSAGE} reset_narrative=${RESET_NARRATIVE} reset_mcp_artifacts=${RESET_MCP_ARTIFACTS} victory_modes=${VICTORY_MODES}"
echo "Log: ${LOG_FILE}"
